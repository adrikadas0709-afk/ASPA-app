# =============================================================
#  ASPA Backend — Environment Variables
#  Copy this file to .env and fill in real values
# =============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/aspa_db
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/aspa_db

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── IBM watsonx.ai ────────────────────────────────────────────
IBM_API_KEY=your_ibm_api_key
IBM_PROJECT_ID=your_ibm_project_id
IBM_REGION=au-syd
IBM_MODEL_ID=ibm/granite-13b-chat-v2
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token
IBM_WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_AUDIO_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/aac,audio/x-wav

# ── IBM Cloud Object Storage (optional) ──────────────────────
COS_ENDPOINT=
COS_API_KEY=
COS_INSTANCE_CRN=
COS_BUCKET=aspa-uploads
